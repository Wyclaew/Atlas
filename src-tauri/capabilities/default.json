{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Atlas main window permissions — local SQLite cache, launching games and opening store URIs",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "opener:default",
    "opener:allow-open-url",
    "shell:allow-open"
  ]
}
