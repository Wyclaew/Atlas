{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atlas",
  "version": "0.2.0",
  "identifier": "com.gamemanager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Atlas",
        "label": "main",
        "width": 1480,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 700,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true,
        "backgroundColor": "#0a0a0c"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost https://api.steampowered.com https://store.steampowered.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
